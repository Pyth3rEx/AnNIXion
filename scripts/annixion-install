#!/usr/bin/env bash
set -euo pipefail

# ── Colours ────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}${BOLD}==> ${RESET}${BOLD}$*${RESET}"; }
success() { echo -e "${GREEN}${BOLD} ✓  $*${RESET}"; }
warn()    { echo -e "${YELLOW}${BOLD}[!] $*${RESET}"; }
die()     { echo -e "${RED}${BOLD}[✗] $*${RESET}" >&2; exit 1; }

# ── Banner ─────────────────────────────────────────────────────────────────
clear
echo -e "${RED}${BOLD}"
cat << 'EOF'
   _            _  _  _  _  _  _
  /_\  _ _  _ _| || || \| || \| |
 / _ \| ' \| ' \ || || .` || .` |
/_/ \_\_||_|_||_|_||_||_|\_||_|\_|
            I N S T A L L E R
EOF
echo -e "${RESET}"
echo -e "  This script will install ${BOLD}AnNIXion${RESET} onto your machine."
echo -e "  ${YELLOW}All data on the chosen disk will be permanently erased.${RESET}\n"

# ── Disk selection ─────────────────────────────────────────────────────────
info "Available disks"
lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -Ev "loop|sr[0-9]"
echo

read -rp "  Disk to install on (e.g. sda, nvme0n1): " DISK_NAME
DISK="/dev/${DISK_NAME}"
[[ -b "$DISK" ]] || die "$DISK is not a block device."

DISK_SIZE=$(lsblk -dno SIZE "$DISK")
echo
warn "ALL DATA ON $DISK ($DISK_SIZE) WILL BE ERASED."
read -rp "  Type 'yes' to confirm: " CONFIRM
[[ "$CONFIRM" == "yes" ]] || { echo "Aborted."; exit 0; }

# ── Partition ──────────────────────────────────────────────────────────────
info "Partitioning $DISK"
parted --script "$DISK" \
  mklabel gpt \
  mkpart ESP fat32 1MiB 512MiB \
  set 1 esp on \
  mkpart primary 512MiB 100%
success "Partitioned"

# Derive partition names (nvme0n1 → nvme0n1p1, sda → sda1)
if [[ "$DISK" == *nvme* || "$DISK" == *mmcblk* ]]; then
  PART_BOOT="${DISK}p1"
  PART_ROOT="${DISK}p2"
else
  PART_BOOT="${DISK}1"
  PART_ROOT="${DISK}2"
fi

# ── Format ─────────────────────────────────────────────────────────────────
info "Formatting partitions"
mkfs.fat -F 32 -n BOOT "$PART_BOOT"
mkfs.ext4 -L nixos "$PART_ROOT"
success "Formatted"

# ── Mount ──────────────────────────────────────────────────────────────────
info "Mounting"
mount /dev/disk/by-label/nixos /mnt
mkdir -p /mnt/boot
mount /dev/disk/by-label/BOOT /mnt/boot
success "Mounted at /mnt"

# ── Fetch AnNIXion config ──────────────────────────────────────────────────
info "Cloning AnNIXion configuration"
git clone https://github.com/Pyth3rEx/AnNIXion /mnt/etc/nixos
success "Cloned to /mnt/etc/nixos"

# ── Hardware config ────────────────────────────────────────────────────────
info "Detecting hardware"
nixos-generate-config --root /mnt --dir /mnt/etc/nixos
success "hardware-configuration.nix written"

# ── Install ────────────────────────────────────────────────────────────────
info "Installing AnNIXion — this will take a while"
echo -e "  ${YELLOW}Tip: security tools are large. Expect 30–60 min on a slow connection.${RESET}\n"
nixos-install --root /mnt --flake /mnt/etc/nixos#AnNIXion --no-root-password

# ── Done ───────────────────────────────────────────────────────────────────
echo
success "Installation complete!"
echo -e "\n  ${BOLD}Login:${RESET}  operator  /  (password set in your configuration)"
echo -e "  ${BOLD}Next:${RESET}   reboot, remove the USB, and boot from disk.\n"
read -rp "  Reboot now? [y/N] " REBOOT
[[ "${REBOOT,,}" == "y" ]] && reboot
